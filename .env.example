# =============================================================================
# Taranac — distribution environment file
#
# Do NOT edit this example for a real install. Run ./install.sh — it generates
# every secret for you and writes a ready .env. This file documents every knob
# and supports advanced/manual installs.
#
# Secrets below are shown as __GENERATE__ placeholders. install.sh fills them
# with cryptographically random values ONCE. After the first start NEVER change
# MASTER_KEY — every encrypted secret in the database becomes undecryptable.
# =============================================================================

# ─── Images ──────────────────────────────────────
# Where to pull the published images from, and which version tag.
IMAGE_PREFIX=ghcr.io/taranaclabs/taranac
TARANAC_VERSION=1.0.2

# ─── Public addressing ───────────────────────────
# The hostname operators/browsers use to reach the admin UI. Drives the edge
# TLS cert SAN, CORS and the MFA enrollment URL.
TARANAC_DOMAIN=taranac.example.com
# Optional separate hostname for the MFA push service (phones). Leave empty to
# keep MFA on its own published port instead of behind the edge proxy.
TARANAC_MFA_DOMAIN=

# Public host ports for the edge proxy (the only web ports you normally expose).
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443

# ─── Public TLS certificate (operator-supplied) ──
# Drop your certificate + key into ./config/tls/ as tls.crt (full chain) and
# tls.key. No Let's Encrypt automation — bring your own. If absent, the edge
# generates a temporary self-signed cert so the stack still boots (browser warns).
TARANAC_TLS_CERT=/etc/taranac/tls/tls.crt
TARANAC_TLS_KEY=/etc/taranac/tls/tls.key

# ─── Database ────────────────────────────────────
POSTGRES_PASSWORD=__GENERATE__
DATABASE_URL=postgresql+asyncpg://taranac:__GENERATE__@postgres:5432/taranac

# Password for the `replicator` role a joining replica streams with. Generated even
# on a single node so a later convert-to-HA already has it. Keep it stable.
POSTGRES_REPLICATION_PASSWORD=__GENERATE__

# This node's name — stable identity for the cluster roster + logs. KEEP IT STABLE
# (the container hostname churns on every recreate). Under HA it MUST be unique per
# node and equal this node's Patroni member name.
TARANAC_NODE_NAME=taranac-node-1

# =============================================================================
# ─── HA / clustering (Pro) — leave this whole block as-is on a single node ───
# Deploying HA? Read docs/guide/ha.md first. Apply docker-compose.ha.yml on top of
# docker-compose.yml on every DB node; run docker-compose.witness.yml on a 3rd host.
# =============================================================================
# List EVERY DB node's Postgres endpoint (comma-separated host[:port]) so writes
# always reach the current primary (target_session_attrs=read-write). ONE
# cluster-wide knob: the API and all three daemons read it (daemons route their
# accounting/session WRITES to the primary, reads stay local). EMPTY on one node.
#   DB_HOSTS=10.0.0.1:5432,10.0.0.2:5432
DB_HOSTS=

# libpq connect_timeout (seconds) for the DB pools. Bounds a connect so that when a
# node's LOCAL Postgres dies/partitions the pool fails fast and the daemon keeps
# answering auth from its in-memory cache (availability > freshness). Rarely changed.
DB_CONNECT_TIMEOUT=3

# ── The HA knobs below are read ONLY when docker-compose.ha.yml is applied ──
# Authoritative HA marker. ha-convert.sh / ha-join.sh set this to 1 on conversion; it
# tells the bundle tooling (./taranac, install.sh, taranac-update.sh) to ALWAYS merge
# docker-compose.ha.yml on this node. Leave UNSET on a standalone node. (A non-empty
# DB_HOSTS is also treated as HA, so you normally never set this by hand.)
#TARANAC_HA=1
# Cluster name — IDENTICAL on every node + the witness (Patroni scope + etcd token).
TARANAC_CLUSTER_NAME=taranac
# This node's address that the OTHER nodes + the witness route to (host IP / DNS).
NODE_ADDRESS=10.0.0.1
# pg_hba TCP scope — NARROW to the cluster's PRIVATE subnet (do not leave wide open).
PG_ALLOW_CIDR=10.0.0.0/24
# etcd (the DCS). ETCD_NAME = this node's member name; ETCD_INITIAL_CLUSTER lists
# EVERY etcd member (each DB node + the witness arbiter) — a 2-node cluster MUST
# include the witness. ETCD_HOSTS = the same members' client endpoints (Patroni).
# ⚠️ etcd speaks plaintext http — FIREWALL 2379/2380 to the private interconnect.
ETCD_NAME=taranac-node-1
ETCD_INITIAL_CLUSTER=taranac-node-1=http://10.0.0.1:2380,taranac-node-2=http://10.0.0.2:2380,witness=http://10.0.0.3:2380
ETCD_INITIAL_CLUSTER_STATE=new
ETCD_HOSTS=10.0.0.1:2379,10.0.0.2:2379,10.0.0.3:2379

# ─── Server ──────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=taranac
APP_VERSION=1.0.2
APP_ENV=production  # production | development | demo (demo enables ./taranac reset)
DOCS_ENABLED=false  # Swagger/Redoc/openapi.json — keep off in production

# ─── Security — JWT ─────────────────────────────
SECRET_KEY=__GENERATE__
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_TOKEN_EXPIRE_MINUTES=5
BCRYPT_ROUNDS=12
# Failed logins before an account is locked.
MAX_LOGIN_ATTEMPTS=5
# Minutes an auto-lockout lasts before the next login self-unlocks it. Turns a
# brute-force attempt into a temporary throttle instead of a permanent account
# lockout (important on a public/demo server). 0 = lock stays until an admin or
# `./taranac unlock` clears it. Manual locks always stay until unlocked.
LOCKOUT_DURATION_MINUTES=15
# Number of reverse proxies in front of the API, so the real client IP is read
# from the trusted (right) end of X-Forwarded-For — a forged leftmost entry must
# not drive lockout/captcha/audit. The standard stack ALWAYS has TWO (the edge
# nginx + the frontend nginx that proxies /api inward) → keep 2. Add 1 per extra
# reverse proxy you front it with (e.g. a public Caddy/CDN terminating TLS → 3).
# 0 = API directly exposed.
TRUSTED_PROXY_HOPS=2

# ─── Encryption — Master Key (KEK) ──────────────
# Fernet key. Generated ONCE. Back it up. Changing it bricks all stored secrets.
MASTER_KEY_SOURCE=env
MASTER_KEY=__GENERATE__
MASTER_KEY_FILE=/run/secrets/master_key

# ─── CORS ────────────────────────────────────────
# Same-origin behind the edge proxy; set to the public https origin.
CORS_ORIGINS=["https://taranac.example.com"]

# ─── Internal TLS verification (server-to-server) ─
INTERNAL_TLS_VERIFY=true

# ─── Logging ─────────────────────────────────────
LOG_LEVEL=INFO
LOG_OUTPUT=stdout

# ─── UI languages ────────────────────────────────
SUPPORTED_LOCALES=en,ru

# ─── Daemon ports (host:container) ───────────────
TACACS_PORT=49
TACACS_TLS_PORT=6049
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
NAC_AUTH_PORT=1814
NAC_ACCT_PORT=1815
NAC_COA_PORT=3799
# Internal-only services — published only when not fronted by the edge proxy.
FRONTEND_PORT=3000
MFA_PORT=8443
CAPTIVE_PORTAL_HTTP_PORT=8080
CAPTIVE_PORTAL_HTTPS_PORT=8444

# ─── Rate limiting ───────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=memory

# ─── Initial admin (first run only) ──────────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@taranac.example.com
INITIAL_ADMIN_PASSWORD=__GENERATE__
INITIAL_ADMIN_GROUP_NAME=Administrators

# ─── Monitoring ──────────────────────────────────
MONITORING_HOST_ROOT=/host

# ─── Taranac MFA service ─────────────────────────
TARANAC_MFA_API_KEY=__GENERATE__
# URL embedded in enrollment QR codes — MUST be reachable from phones.
# Behind the edge proxy with TARANAC_MFA_DOMAIN set, this is https://<that>/ttype/push.
TARANAC_MFA_PUSH_REGISTRATION_URL=https://mfa.example.com/ttype/push

# ─── Internal API key (daemons → backend) ────────
INTERNAL_API_KEY=__GENERATE__
